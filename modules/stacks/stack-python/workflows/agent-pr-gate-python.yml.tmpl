name: agent-pr-gate-python

on:
  pull_request:
    branches: ["**"]

permissions:
  contents: read

jobs:
  gate:
    name: Python PR Gate
    runs-on: ubuntu-latest
    timeout-minutes: 20
    env:
      PYTHON_VERSION: "{{ python_version }}"
      PACKAGE_MANAGER: "{{ package_manager }}"
      TEST_RUNNER: "{{ test_runner }}"
      LINTER: "{{ linter }}"
      COVERAGE_MIN: "80"
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "{{ python_version }}"
          cache: pip

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          case "{{ package_manager }}" in
            pip)
              if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
              if [ -f requirements-dev.txt ]; then pip install -r requirements-dev.txt; fi
              pip install "{{ linter }}" black pytest pytest-cov
              ;;
            poetry)
              pip install poetry
              poetry install --with dev --no-interaction --no-root
              ;;
            uv)
              pip install uv
              uv sync --all-extras --dev
              ;;
            *)
              echo "Unknown package manager: {{ package_manager }}" && exit 1
              ;;
          esac

      - name: Format check
        run: black --check .

      - name: Lint
        run: |
          case "{{ linter }}" in
            ruff)   ruff check . ;;
            flake8) flake8 . ;;
            *) echo "Unknown linter: {{ linter }}" && exit 1 ;;
          esac

      - name: Test with coverage
        run: |
          case "{{ test_runner }}" in
            pytest)
              pytest --cov=. --cov-report=term-missing --cov-report=xml --cov-fail-under=${COVERAGE_MIN}
              ;;
            unittest)
              python -m unittest discover -s tests -v
              ;;
            *) echo "Unknown test runner: {{ test_runner }}" && exit 1 ;;
          esac

      - name: Upload coverage artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: python-coverage
          path: coverage.xml
          if-no-files-found: ignore
