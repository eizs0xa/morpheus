name: agent-pr-gate-react

on:
  pull_request:
    branches: ["**"]

permissions:
  contents: read

jobs:
  gate:
    name: React PR Gate
    runs-on: ubuntu-latest
    timeout-minutes: 25
    env:
      REACT_VERSION: "{{ react_version }}"
      BUNDLER: "{{ bundler }}"
      TEST_RUNNER: "{{ test_runner }}"
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: pnpm

      - name: Enable Corepack
        run: corepack enable

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Verify React version
        run: |
          node -e "const v='{{ react_version }}'; const r=require('react/package.json').version; if(!r.startsWith(v+'.')){console.error('React major mismatch: want '+v+', got '+r); process.exit(1);}"

      - name: Lint
        run: pnpm run lint

      - name: Typecheck
        run: pnpm run typecheck

      - name: Test
        env:
          RUNNER: "{{ test_runner }}"
        run: |
          case "{{ test_runner }}" in
            vitest)     pnpm exec vitest run --coverage ;;
            jest)       pnpm exec jest --coverage ;;
            playwright) pnpm exec playwright install --with-deps && pnpm exec playwright test ;;
            *) echo "Unknown test runner: {{ test_runner }}" && exit 1 ;;
          esac

      - name: Build
        run: |
          case "{{ bundler }}" in
            vite)    pnpm run build ;;
            next)    pnpm run build ;;
            webpack) pnpm run build ;;
            *) echo "Unknown bundler: {{ bundler }}" && exit 1 ;;
          esac
